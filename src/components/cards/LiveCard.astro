---
// No props — data fetched client-side
---

<div class="bento-card col-span-1 lg:min-h-0 p-4 lg:p-[clamp(0.75rem,3cqw,1.25rem)] flex flex-col justify-between gap-2 lg:gap-[clamp(0.25rem,2cqw,0.75rem)] overflow-hidden" style="flex: 1">
    <div class="flex items-center justify-between gap-2">
        <p
            class="text-sm lg:text-[clamp(0.65rem,2.8cqw,0.9rem)] text-(--accent) font-semibold uppercase tracking-wide whitespace-nowrap"
        >
            Where I am
        </p>
        <p id="bkk-date" class="text-base lg:text-[clamp(0.65rem,2.8cqw,0.95rem)] uppercase tracking-wide whitespace-nowrap">---</p>
    </div>

    <div class="flex items-center justify-between gap-2">
        <p class="text-base lg:text-[clamp(0.8rem,4cqw,1.15rem)] text-white font-semibold whitespace-nowrap">Bangkok, TH</p>
        <p
            id="bkk-time"
            class="text-xl lg:text-[clamp(0.8rem,6cqw,1.5rem)] font-bold text-white tabular-nums leading-none whitespace-nowrap"
        >
            --:--:--
        </p>
    </div>
</div>

<script>
    function updateClock() {
        const now = new Date();
        const el = (id: string) => document.getElementById(id)!;
        el("bkk-time").textContent = now.toLocaleTimeString("en-US", {
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
            hour12: false,
            timeZone: "Asia/Bangkok",
        });
        el("bkk-date").textContent = now.toLocaleDateString("en-US", {
            weekday: "short",
            month: "short",
            day: "numeric",
            timeZone: "Asia/Bangkok",
        });
    }

    updateClock();
    setInterval(updateClock, 1000);
</script>
