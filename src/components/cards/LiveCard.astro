---
// No props — data fetched client-side
---

<div class="bento-card col-span-1 p-4 flex flex-col gap-2" style="flex: 1">
    <div class="flex items-center justify-between">
        <p
            class="text-sm text-(--accent) font-semibold uppercase tracking-wide"
        >
            Where I am
        </p>
        <p id="bkk-date" class="text-base uppercase tracking-wide">---</p>
    </div>

    <div class="flex items-center justify-between">
        <p class="text-base text-white font-semibold">Bangkok, TH</p>
        <p
            id="bkk-time"
            class="text-2xl font-bold text-white tabular-nums leading-none"
        >
            --:--:--
        </p>
    </div>
</div>

<script>
    function updateClock() {
        const now = new Date();
        const el = (id: string) => document.getElementById(id)!;
        el("bkk-time").textContent = now.toLocaleTimeString("en-US", {
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
            hour12: false,
            timeZone: "Asia/Bangkok",
        });
        el("bkk-date").textContent = now.toLocaleDateString("en-US", {
            weekday: "short",
            month: "short",
            day: "numeric",
            timeZone: "Asia/Bangkok",
        });
    }

    updateClock();
    setInterval(updateClock, 1000);
</script>
