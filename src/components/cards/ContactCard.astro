---
import Icon from '../ui/Icon.astro';

interface Social {
  name: string;
  url: string;
  icon: string;
}
interface Props {
  email: string;
  phone: string;
  social: Social[];
}
const { email, phone, social } = Astro.props;
---
<div
  class="bento-card clickable col-span-1 lg:row-span-3 p-6 flex flex-col gap-4"
  style="min-height: 200px"
  @click="modal = 'contact'"
>
  <!-- Header -->
  <div class="flex items-center justify-between">
    <p class="text-sm text-(--accent) font-semibold uppercase tracking-wide">Get in touch</p>
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-(--very-dim)">
      <path d="M7 17L17 7M7 7h10v10"/>
    </svg>
  </div>

  <!-- Contact rows -->
  <div class="flex flex-col gap-2.5">
    <div class="flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-lg bg-(--inner-bg) border border-(--card-border) flex items-center justify-center flex-shrink-0">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke-width="2" style="stroke: var(--muted2)">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>
      <span class="text-xs text-(--muted) truncate">{email}</span>
    </div>

    <div class="flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-lg bg-(--inner-bg) border border-(--card-border) flex items-center justify-center flex-shrink-0">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke-width="2" style="stroke: var(--muted2)">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
      </div>
      <span class="text-xs text-(--muted2)">{phone}</span>
    </div>
  </div>

  <!-- Divider -->
  <div class="border-t border-(--card-border)"></div>

  <!-- Social icon buttons -->
  <div class="flex flex-wrap gap-2">
    {social.map((s) => (
      <a
        href={s.url}
        target="_blank"
        rel="noopener"
        title={s.name}
        class="w-8 h-8 rounded-lg bg-(--inner-bg) border border-(--card-border) flex items-center justify-center text-(--muted) hover:border-(--accent) hover:text-(--accent) transition-colors"
        @click.stop
      >
        <Icon name={s.icon} size={14} />
      </a>
    ))}
  </div>
</div>
