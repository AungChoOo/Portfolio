---
interface Props {
    name: string;
    title: string;
    tagline: string;
    resumeUrl: string;
}
const { name, title, tagline, resumeUrl } = Astro.props;
---

<div
    class="bento-card col-span-3 relative p-8 flex flex-col justify-between"
    style="min-height: 260px"
>
    <div
        class="absolute inset-0 overflow-hidden rounded-2xl pointer-events-none"
    >
        <img
            src="/images/Robot.png"
            alt=""
            class="w-60 h-70 object-cover opacity-[0.5] scale-110"
            style="object-position: 0% center"
        />
        <div
            class="absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-(--accent)/5"
        >
        </div>
    </div>

    <div class="relative z-10 text-right">
        <h1 class="text-5xl font-bold text-white mb-2 leading-tight">{name}</h1>
        <p class="text-lg text-(--muted) mb-3">{title}</p>
        <p class="text-sm text-(--muted2) italic">"{tagline}"</p>
    </div>

    <div class="relative z-10 flex gap-3 mt-6 flex-wrap justify-end">
        <a
            href={resumeUrl}
            target="_blank"
            rel="noopener"
            class="px-5 py-2.5 bg-(--accent) text-black text-sm font-semibold rounded-lg hover:bg-(--accent-hover) transition-colors inline-block"
        >
            View Resume
        </a>
    </div>
</div>
