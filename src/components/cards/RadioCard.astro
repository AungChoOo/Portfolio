---
const station = {
    name: "Groove Salad",
    url:  "https://ice1.somafm.com/groovesalad-128-mp3",
};

const bands = Array.from({ length: 16 }, (_, i) => ({
    band: i,
    dur:  (0.55 + Math.abs(Math.sin(i * 1.3)) * 0.55).toFixed(2),
    delay:(Math.abs(Math.cos(i * 0.9)) * 0.65).toFixed(2),
    maxH: Math.round(45 + Math.abs(Math.sin(i * 0.8 + 0.5)) * 45),
}));

const bars = [...bands].reverse().concat(bands);
---

<div
    class="bento-card col-span-1 lg:col-span-1 flex flex-row items-stretch p-4 gap-3"
    style="flex: 1; background: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.55)), url('/images/music.jpg') center/cover no-repeat"
>
    <div class="flex flex-col items-center justify-center">
        <button
            type="button"
            data-radio-btn
            aria-label="Mute radio"
            class="p-2 rounded-full transition-colors cursor-pointer"
            style="color:var(--accent)"
        >
            <svg data-icon-muted width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                <path d="M9 9L19.5 6M19.5 12.5528V16.3028C19.5 17.3074 18.834 18.1903 17.8681 18.4663L16.5481 18.8434C15.3964 19.1724 14.25 18.3077 14.25 17.1099C14.25 16.305 14.7836 15.5975 15.5576 15.3764L17.8681 14.7163C18.834 14.4403 19.5 13.5574 19.5 12.5528ZM19.5 12.5528V2.25L9 5.25V15.5528M9 15.5528V19.3028C9 20.3074 8.33405 21.1903 7.36812 21.4663L6.04814 21.8434C4.89645 22.1724 3.75 21.3077 3.75 20.1099C3.75 19.305 4.2836 18.5975 5.05757 18.3764L7.36812 17.7163C8.33405 17.4403 9 16.5574 9 15.5528Z"/>
                <line x1="3" y1="21" x2="21" y2="3"/>
            </svg>
            <svg data-icon-playing width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="spin-playing">
                <path d="M9 9L19.5 6M19.5 12.5528V16.3028C19.5 17.3074 18.834 18.1903 17.8681 18.4663L16.5481 18.8434C15.3964 19.1724 14.25 18.3077 14.25 17.1099C14.25 16.305 14.7836 15.5975 15.5576 15.3764L17.8681 14.7163C18.834 14.4403 19.5 13.5574 19.5 12.5528ZM19.5 12.5528V2.25L9 5.25V15.5528M9 15.5528V19.3028C9 20.3074 8.33405 21.1903 7.36812 21.4663L6.04814 21.8434C4.89645 22.1724 3.75 21.3077 3.75 20.1099C3.75 19.305 4.2836 18.5975 5.05757 18.3764L7.36812 17.7163C8.33405 17.4403 9 16.5574 9 15.5528Z"/>
            </svg>
        </button>
    </div>

    <div class="flex-1 flex flex-col gap-1 min-w-0">
        <p
            class="text-[9px] uppercase tracking-widest truncate"
            style="color:var(--muted2)"
        >{station.name}</p>

        <div class="flex-1 flex items-end justify-between gap-0.5 min-w-0">
            {bars.map(b => (
                <div
                    class="eq-bar playing w-1 rounded-full"
                    data-band={b.band}
                    style={`--dur:${b.dur}s;--delay:${b.delay}s;--max-h:${b.maxH}%;background:var(--accent);height:4px`}
                ></div>
            ))}
        </div>
    </div>

    <audio
        data-radio-audio
        src={station.url}
        preload="none"
        crossorigin="anonymous"
    ></audio>
</div>

<style>
    @keyframes eq {
        0%, 100% { height: 4px; }
        50%       { height: var(--max-h); }
    }
    .eq-bar.playing {
        animation: eq var(--dur) ease-in-out infinite var(--delay);
    }

    @keyframes spin-slow {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }
    .spin-playing {
        animation: spin-slow 4s linear infinite;
    }
    .spin-playing.paused {
        animation-play-state: paused;
    }

    @keyframes click-bounce {
        0%   { transform: scale(1); }
        40%  { transform: scale(0.82); }
        70%  { transform: scale(1.15); }
        100% { transform: scale(1); }
    }
    .click-bounce {
        animation: click-bounce 0.35s ease-out forwards;
    }
</style>

<script>
    const btn         = document.querySelector('[data-radio-btn]') as HTMLButtonElement;
    const audio       = document.querySelector('[data-radio-audio]') as HTMLAudioElement;
    const bars        = document.querySelectorAll<HTMLElement>('.eq-bar');
    const iconMuted   = document.querySelector('[data-icon-muted]') as SVGElement;
    const iconPlaying = document.querySelector('[data-icon-playing]') as SVGElement;

    let ctx: AudioContext | null = null;
    let analyser: AnalyserNode | null = null;
    let raf: number;
    let webAudio = false;
    let playing = true;
    let audioStarted = false;

    function animateAnalyser() {
        if (!analyser) return;
        const data = new Uint8Array(analyser.frequencyBinCount);
        analyser.getByteFrequencyData(data);
        const bandCount = 16;
        const step = Math.max(1, Math.floor(data.length / bandCount));
        bars.forEach((bar) => {
            const band = parseInt(bar.dataset.band || '0', 10);
            const val = data[band * step] / 255;
            bar.style.height = Math.max(4, val * bar.parentElement!.clientHeight * 0.95) + 'px';
        });
        raf = requestAnimationFrame(animateAnalyser);
    }

    function triggerClickBounce() {
        iconPlaying.classList.remove('click-bounce');
        void (iconPlaying as Element).getBoundingClientRect(); // reflow to restart animation
        iconPlaying.classList.add('click-bounce');
        iconPlaying.addEventListener('animationend', () =>
            iconPlaying.classList.remove('click-bounce'), { once: true }
        );
    }

    function setPlaying(state: boolean) {
        playing = state;
        iconMuted.style.display   = state ? 'none' : '';
        iconPlaying.style.display = state ? '' : 'none';
        iconPlaying.classList.toggle('paused', !state);
        btn.style.color = state ? 'var(--accent)' : 'var(--muted)';
        btn.setAttribute('aria-label', state ? 'Mute radio' : 'Play radio');

        if (state) {
            if (webAudio) {
                bars.forEach(b => b.classList.remove('playing'));
                animateAnalyser();
            } else {
                bars.forEach(b => b.classList.add('playing'));
            }
        } else {
            cancelAnimationFrame(raf);
            bars.forEach(b => {
                b.classList.remove('playing');
                b.style.height = '4px';
            });
        }
    }

    async function initAudioContext() {
        if (ctx) return;
        ctx = new AudioContext();
        analyser = ctx.createAnalyser();
        analyser.fftSize = 64;
        analyser.smoothingTimeConstant = 0.8;
        try {
            const source = ctx.createMediaElementSource(audio);
            source.connect(analyser);
            analyser.connect(ctx.destination);
            webAudio = true;
        } catch {
            webAudio = false;
        }
    }

    async function startAudio() {
        await initAudioContext();
        if (ctx!.state === 'suspended') await ctx!.resume();
        try {
            await audio.play();
            audioStarted = true;
            setPlaying(true);
            return true;
        } catch {
            return false;
        }
    }

    btn.addEventListener('click', async () => {
        triggerClickBounce();
        if (!audioStarted) {
            await startAudio();
            return;
        }
        if (playing) {
            audio.pause();
            setPlaying(false);
        } else {
            await startAudio();
        }
    });

    // Try autoplay on load; if blocked, start on first user interaction anywhere.
    (async () => {
        if (await startAudio()) return;
        const onFirstInteraction = async () => {
            document.removeEventListener('pointerdown', onFirstInteraction);
            document.removeEventListener('keydown', onFirstInteraction);
            await startAudio();
        };
        document.addEventListener('pointerdown', onFirstInteraction, { once: true });
        document.addEventListener('keydown', onFirstInteraction, { once: true });
    })();
</script>
