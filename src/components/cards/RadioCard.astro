---
const station = {
    name: "Lo-Fi",
    url:  "https://lofi.stream.laut.fm/lofi",
};

const bands = Array.from({ length: 16 }, (_, i) => ({
    band: i,
    dur:  (0.55 + Math.abs(Math.sin(i * 1.3)) * 0.55).toFixed(2),
    delay:(Math.abs(Math.cos(i * 0.9)) * 0.65).toFixed(2),
    maxH: Math.round(30 + Math.abs(Math.sin(i * 0.8 + 0.5)) * 35),
}));

const bars = [...bands].reverse().concat(bands);
---

<div
    class="bento-card col-span-1 lg:col-span-1 lg:min-h-0 flex flex-row items-stretch p-4 lg:p-[clamp(0.5rem,1.2vh,1rem)] gap-3 radio-card"
    style="flex: 1; position: relative"
>
    <div class="flex flex-col items-center justify-center">
        <button
            type="button"
            data-radio-btn
            aria-label="Mute radio"
            class="p-2 rounded-full transition-colors cursor-pointer"
            style="color:var(--accent)"
        >
            <span data-icon-muted class="clef-icon" style="display:none; position:relative;">
                𝄞
                <svg class="clef-slash" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                    <line x1="3" y1="21" x2="21" y2="3"/>
                </svg>
            </span>
            <span data-icon-playing class="clef-icon spin-playing">𝄞</span>
        </button>
    </div>

    <div class="flex-1 flex flex-col gap-1.5 min-w-0">
        <div class="flex-1 flex items-end justify-between gap-0.5 min-w-0">
            {bars.map(b => (
                <div
                    class="eq-bar playing w-1 rounded-full"
                    data-band={b.band}
                    style={`--dur:${b.dur}s;--delay:${b.delay}s;--max-h:${b.maxH}%;background:var(--accent);height:2px`}
                ></div>
            ))}
        </div>
        <input
            type="range"
            data-volume
            min="0" max="1" step="0.02" value="0.5"
            class="volume-slider"
            aria-label="Volume"
        />
    </div>

    <audio
        data-radio-audio
        src={station.url}
        preload="none"
        crossorigin="anonymous"
    ></audio>
</div>

<style>
    .radio-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.55)), url('/images/Music.jpg') center/cover no-repeat;
        border-radius: 1rem;
        pointer-events: none;
    }

    .radio-card > * {
        position: relative;
        z-index: 1;
    }

    .clef-icon {
        display: inline-block;
        font-size: 2rem;
        font-family: 'Segoe UI Symbol', Georgia, 'Times New Roman', serif;
        line-height: 1;
        width: 2rem;
        text-align: center;
    }
    .clef-slash {
        position: absolute;
        inset: -4px;
        width: calc(100% + 8px);
        height: calc(100% + 8px);
        pointer-events: none;
    }

    .volume-slider {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 3px;
        border-radius: 2px;
        background: var(--inner-bg);
        outline: none;
        cursor: pointer;
    }
    .volume-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--accent);
        cursor: pointer;
        transition: transform 0.15s ease;
    }
    .volume-slider::-moz-range-thumb {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: none;
        background: var(--accent);
        cursor: pointer;
    }
    .volume-slider::-webkit-slider-thumb:hover { transform: scale(1.4); }

    @keyframes eq {
        0%, 100% { height: 2px; }
        50%       { height: var(--max-h); }
    }
    .eq-bar.playing {
        animation: eq var(--dur) ease-in-out infinite var(--delay);
    }

    @keyframes spin-slow {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }
    .spin-playing {
        animation: spin-slow 4s linear infinite;
    }
    .spin-playing.paused {
        animation-play-state: paused;
    }

    @keyframes click-bounce {
        0%   { transform: scale(1); }
        40%  { transform: scale(0.82); }
        70%  { transform: scale(1.15); }
        100% { transform: scale(1); }
    }
    .click-bounce {
        animation: click-bounce 0.35s ease-out forwards;
    }
</style>

<script>
    const btn          = document.querySelector('[data-radio-btn]') as HTMLButtonElement;
    const audio        = document.querySelector('[data-radio-audio]') as HTMLAudioElement;
    const bars         = document.querySelectorAll<HTMLElement>('.eq-bar');
    const iconMuted    = document.querySelector('[data-icon-muted]') as HTMLElement;
    const iconPlaying  = document.querySelector('[data-icon-playing]') as HTMLElement;
    const volumeSlider = document.querySelector('[data-volume]') as HTMLInputElement;

    audio.volume = 0.5;
    volumeSlider.addEventListener('input', () => {
        audio.volume = parseFloat(volumeSlider.value);
    });

    let ctx: AudioContext | null = null;
    let analyser: AnalyserNode | null = null;
    let raf: number;
    let webAudio = false;
    let playing = true;
    let audioStarted = false;

    function animateAnalyser() {
        if (!analyser) return;
        const data = new Uint8Array(analyser.frequencyBinCount);
        analyser.getByteFrequencyData(data);
        const bandCount = 16;
        const step = Math.max(1, Math.floor(data.length / bandCount));
        bars.forEach((bar) => {
            const band = parseInt(bar.dataset.band || '0', 10);
            const val = data[band * step] / 255;
            bar.style.height = Math.max(2, val * bar.parentElement!.clientHeight * 0.95) + 'px';
        });
        raf = requestAnimationFrame(animateAnalyser);
    }

    function triggerClickBounce() {
        iconPlaying.classList.remove('click-bounce');
        void (iconPlaying as Element).getBoundingClientRect(); // reflow to restart animation
        iconPlaying.classList.add('click-bounce');
        iconPlaying.addEventListener('animationend', () =>
            iconPlaying.classList.remove('click-bounce'), { once: true }
        );
    }

    function setPlaying(state: boolean) {
        playing = state;
        iconMuted.style.display   = state ? 'none' : '';
        iconPlaying.style.display = state ? '' : 'none';
        iconPlaying.classList.toggle('paused', !state);
        btn.style.color = state ? 'var(--accent)' : 'var(--muted)';
        btn.setAttribute('aria-label', state ? 'Mute radio' : 'Play radio');

        if (state) {
            if (webAudio) {
                bars.forEach(b => b.classList.remove('playing'));
                animateAnalyser();
            } else {
                bars.forEach(b => b.classList.add('playing'));
            }
        } else {
            cancelAnimationFrame(raf);
            bars.forEach(b => {
                b.classList.remove('playing');
                b.style.height = '2px';
            });
        }
    }

    // Set up Web Audio for the analyser. MUST only be called from a user
    // gesture — otherwise the AudioContext is created in 'suspended' state and
    // MediaElementSource bypasses the audio element's native output, silencing
    // playback. Bars fall back to CSS animation until this runs.
    async function attachVisualizer() {
        if (ctx) {
            if (ctx.state === 'suspended') await ctx.resume();
            return;
        }
        try {
            ctx = new AudioContext();
            if (ctx.state === 'suspended') await ctx.resume();
            analyser = ctx.createAnalyser();
            analyser.fftSize = 64;
            analyser.smoothingTimeConstant = 0.8;
            const source = ctx.createMediaElementSource(audio);
            source.connect(analyser);
            analyser.connect(ctx.destination);
            webAudio = true;
            if (playing) {
                bars.forEach(b => b.classList.remove('playing'));
                animateAnalyser();
            }
        } catch {
            webAudio = false;
        }
    }

    async function tryPlay() {
        try {
            await audio.play();
            return true;
        } catch {
            return false;
        }
    }

    async function startAudio() {
        if (!(await tryPlay())) return false;
        audioStarted = true;
        setPlaying(true);
        await attachVisualizer();
        return true;
    }

    // Pending action to run on the user's first interaction, if the radio
    // isn't fully running with sound + analyser yet on load.
    let pendingFirstAction: (() => void | Promise<void>) | null = null;

    function consumePendingAction() {
        document.removeEventListener('pointerdown', onAnyFirstInteraction);
        document.removeEventListener('keydown', onAnyFirstInteraction);
        const action = pendingFirstAction;
        pendingFirstAction = null;
        action?.();
    }

    function onAnyFirstInteraction(e: Event) {
        // Defer to the button's own handler if the user clicked it directly.
        if (btn.contains(e.target as Node)) return;
        consumePendingAction();
    }

    btn.addEventListener('click', async () => {
        triggerClickBounce();
        if (pendingFirstAction) {
            consumePendingAction();
            return;
        }
        if (playing) {
            audio.pause();
            setPlaying(false);
        } else {
            await startAudio();
        }
    });

    (async () => {
        // 1. Try plain autoplay first (works on revisits with browser engagement).
        if (await tryPlay()) {
            audioStarted = true;
            setPlaying(true);
            // Web Audio needs a user gesture; defer the visualizer hookup.
            pendingFirstAction = () => { attachVisualizer(); };
        }
        // 2. Try muted autoplay (browsers always allow this).
        else {
            audio.muted = true;
            if (await tryPlay()) {
                audioStarted = true;
                setPlaying(true);
                pendingFirstAction = () => {
                    audio.muted = false;
                    attachVisualizer();
                };
            }
            // 3. Everything blocked — start unmuted on first interaction.
            else {
                audio.muted = false;
                pendingFirstAction = () => { startAudio(); };
            }
        }
        document.addEventListener('pointerdown', onAnyFirstInteraction);
        document.addEventListener('keydown', onAnyFirstInteraction);
    })();
</script>
