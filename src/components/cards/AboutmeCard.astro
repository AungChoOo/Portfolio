---
interface Props {
    name: string;
    title: string;
    resumeUrl: string;
}
const { name, title, resumeUrl } = Astro.props;
---

<div
    class="bento-card clickable col-span-1 lg:col-span-3 lg:row-span-3 relative p-8 flex flex-col justify-start"
    style="min-height: 260px"
    @click="modal = 'about'"
>
    <div
        class="absolute inset-0 overflow-hidden rounded-2xl pointer-events-none"
    >
        <img
            src="/images/Robot.png"
            alt=""
            class="absolute right-0 top-0 w-60 h-75 object-cover opacity-[0.5] scale-110"
            style="object-position: 0% center; transform: scaleX(-1)"
        />
        <div
            class="absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-(--accent)/5"
        >
        </div>
    </div>

    <div class="relative z-10 text-left flex-1 flex flex-col justify-center">
        <h1
            class="text-5xl font-bold text-(--text) mb-2 leading-tight"
            style="font-family: 'Birthstone', cursive"
        >
            {name}
        </h1>
        <p class="text-lg text-(--muted) -mb-4">{title}</p>
    </div>

    <div class="relative z-10 flex gap-3 flex-wrap justify-start">
        <a
            href={resumeUrl}
            target="_blank"
            rel="noopener"
            class="px-5 py-2.5 bg-(--accent) text-black text-sm font-semibold rounded-lg hover:bg-(--accent-hover) transition-colors inline-block"
        >
            View Resume
        </a>
    </div>
</div>
