---
interface Project {
  id: string;
  data: {
    title: string;
    description: string;
    tags: string[];
    image: string;
    repo?: string;
    url?: string;
    featured: boolean;
    order: number;
  };
}
interface Props {
  projects: Project[];
}
const { projects } = Astro.props;
const featured = projects.find((p) => p.data.featured) ?? projects[0];
---
<div
  class="bento-card clickable col-span-1 flex flex-col"
  @click="modal = 'projects'"
>
  <!-- Header section -->
  <div class="px-4 py-3 border-b border-(--card-border) flex items-center justify-between">
    <p class="text-sm text-(--accent) font-semibold uppercase tracking-wide">Feature projects</p>
  </div>

  <!-- Image section -->
  <div class="relative flex-shrink-0 overflow-hidden" style="height: 150px">
    <img
      src={featured.data.image}
      alt={featured.data.title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/30"></div>
  </div>

  <!-- Info section -->
  <div class="p-4 border-t border-(--card-border) flex flex-col gap-2">
    <h3 class="text-white text-sm font-semibold leading-snug truncate">{featured.data.title}</h3>
    <p class="text-(--muted) text-xs leading-relaxed" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
      {featured.data.description}
    </p>
    <div class="flex gap-1 flex-wrap">
      {featured.data.tags.slice(0, 3).map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>
</div>
