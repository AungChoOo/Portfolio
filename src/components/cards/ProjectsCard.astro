---
interface Props {
    projects: any[];
}
const { projects } = Astro.props;
---

<div
    class="bento-card clickable col-span-1 lg:min-h-0 flex flex-col items-center justify-center overflow-hidden"
    style="flex: 1.5; background: linear-gradient(135deg, var(--card-bg), color-mix(in srgb, var(--accent) 15%, var(--card-bg)))"
    @click="modal = 'projects'"
>
    <p
        class="font-bold text-(--accent) text-6xl lg:text-[clamp(2.25rem,7vh,3.75rem)] leading-none"
        style="font-family: 'Tangerine', cursive"
    >
        Portfolio
    </p>
</div>
