---
import Base from "../layouts/Base.astro";
import AboutmeCard from "../components/cards/AboutmeCard.astro";
import HeroCard from "../components/cards/HeroCard.astro";
import SkillsCard from "../components/cards/SkillsCard.astro";
import ContactCard from "../components/cards/ContactCard.astro";
import LiveCard from "../components/cards/LiveCard.astro";
import ProjectsCard from "../components/cards/ProjectsCard.astro";
import ExperienceCard from "../components/cards/ExperienceCard.astro";
import RadioCard from "../components/cards/RadioCard.astro";
import Icon from "../components/ui/Icon.astro";
import Modal from "../components/ui/Modal.astro";
import portfolioData from "../data/portfolio.json";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);

const { personal, social, about, skills, experience } = portfolioData;
const skillItems = skills.filter((s) => s.category === "skills");
const toolItems = skills.filter((s) => s.category === "tools");
---

<Base>
    <div
        x-data=`{
            modal: null,
            email: '${personal.email}',
            phone: '${personal.phone}',
            toast: null,
            showToast(message) {
                this.toast = message;
                setTimeout(() => { this.toast = null; }, 2000);
            }
        }`
        @keydown.escape.window="modal = null"
        class="min-h-screen px-4 pt-4 pb-4 md:px-6 md:pt-8 md:pb-6 lg:h-screen lg:min-h-0 lg:overflow-hidden lg:flex lg:flex-col lg:p-[clamp(0.75rem,2vh,1.75rem)]"
    >
        <div
            class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-4 lg:grid-rows-6 gap-3 auto-rows-auto lg:flex-1 lg:min-h-0 lg:gap-[clamp(0.5rem,1.4vh,1rem)]"
        >
            <HeroCard name={personal.name} />
            <AboutmeCard
                name={personal.name}
                title={personal.title}
                resumeUrl={personal.resumeUrl}
            />

            <SkillsCard skillItems={skillItems} toolItems={toolItems} />

            <div class="col-span-1 lg:row-span-3 lg:min-h-0 flex flex-col gap-3 lg:gap-[clamp(0.5rem,1.4vh,1rem)]">
                <ProjectsCard />
                <ExperienceCard />
                <LiveCard />
            </div>
            <ContactCard
                email={personal.email}
                phone={personal.phone}
                social={social}
            />
            <RadioCard />
        </div>

        <div
            x-cloak
            x-show="modal !== null"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            @click.self="modal = null"
            class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4 overflow-y-auto"
        >
            <Modal name="about">
                <div class="flex items-start gap-4 md:gap-5 mb-6">
                    <img
                        src="/images/Profile.png"
                        alt={personal.name}
                        class="w-16 md:w-20 h-16 md:h-20 rounded-xl object-cover flex-shrink-0 border"
                        style="object-position: center 10%; border-color: var(--card-bg)"
                    />
                    <div>
                        <p
                            class="text-[10px] text-(--accent) font-mono uppercase tracking-widest mb-1"
                        >
                            About
                        </p>
                        <h2 class="text-xl font-bold text-white">
                            {personal.name}
                        </h2>
                        <p class="text-(--muted) text-sm">
                            {personal.title}
                        </p>
                    </div>
                </div>
                <p class="text-(--muted) text-sm leading-relaxed mb-6">
                    {about.description}
                </p>
                <div class="grid grid-cols-2 gap-3">
                    <div
                        class="bg-(--inner-bg) border border-(--card-border) rounded-xl p-4 text-center"
                    >
                        <p class="text-2xl font-bold text-(--accent)">5+</p>
                        <p class="text-xs text-(--muted) mt-1">
                            Years Experience
                        </p>
                    </div>
                    <div
                        class="bg-(--inner-bg) border border-(--card-border) rounded-xl p-4 text-center"
                    >
                        <p class="text-2xl font-bold text-(--accent)">50+</p>
                        <p class="text-xs text-(--muted) mt-1">
                            Projects Completed
                        </p>
                    </div>
                </div>
            </Modal>

            <Modal name="skills">
                <div class="space-y-4 mb-6">
                    <div class="flex items-center gap-2">
                        <Icon name="cpu" size={14} class="text-(--accent)" />
                        <p
                            class="text-xs text-(--muted2) uppercase tracking-wider"
                        >
                            Skills
                        </p>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        {
                            skillItems.map((skill) => (
                                <div class="text-sm">
                                    <p class="text-(--text) font-medium">
                                        {skill.name}
                                    </p>
                                    {skill.subskills && (
                                        <p class="text-xs text-(--muted2) mt-1">
                                            {skill.subskills.join(", ")}
                                        </p>
                                    )}
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div class="h-px bg-gradient-to-r from-transparent via-(--card-border) to-transparent mb-6"></div>

                <div class="space-y-4">
                    <div class="flex items-center gap-2">
                        <Icon name="wrench" size={14} class="text-(--accent)" />
                        <p
                            class="text-xs text-(--muted2) uppercase tracking-wider"
                        >
                            Tools
                        </p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {
                            toolItems.map((skill) =>
                                skill.icon ? (
                                    <div class="flex items-center gap-2 px-3 py-1.5 bg-(--inner-bg) border border-(--card-border) rounded-lg text-(--text) hover:border-(--accent) hover:text-(--accent) transition-colors">
                                        <Icon name={skill.icon} size={14} />
                                        <span class="text-sm">
                                            {skill.name}
                                        </span>
                                    </div>
                                ) : (
                                    <span class="text-sm px-3 py-1.5 bg-(--inner-bg) border border-(--card-border) rounded-lg text-(--text)">
                                        {skill.name}
                                    </span>
                                ),
                            )
                        }
                    </div>
                </div>
            </Modal>

            <Modal name="experience" eyebrow="Experience" heading="Work Experience">
                <div class="space-y-4">
                    {
                        experience.map((exp) => (
                            <div class="bg-(--inner-bg) border border-(--card-border) rounded-xl p-4">
                                <div class="flex items-start justify-between gap-2 mb-1">
                                    <h3 class="text-white font-semibold text-sm">
                                        {exp.role}
                                    </h3>
                                    <span class="text-xs text-(--muted2) flex-shrink-0">
                                        {exp.period}
                                    </span>
                                </div>
                                <div class="flex items-center gap-2 mb-2">
                                    <p class="text-(--accent) text-xs">
                                        {exp.company}
                                    </p>
                                    {exp.location && (
                                        <span class="text-(--muted2) text-xs">
                                            · {exp.location}
                                        </span>
                                    )}
                                </div>
                                <ul class="space-y-1">
                                    {exp.description.map((point) => (
                                        <li class="text-(--muted) text-xs leading-relaxed flex gap-2">
                                            <span class="text-(--accent) flex-shrink-0">
                                                ·
                                            </span>
                                            <span>{point}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        ))
                    }
                </div>
            </Modal>

            <Modal
                name="contact"
                width="md:max-w-md"
                eyebrow="Contact"
                heading="Get in Touch"
            >
                <div class="space-y-3 mb-6">
                    <button
                        @click.stop="navigator.clipboard.writeText(email); showToast('Copied email to clipboard')"
                        class="w-full flex items-center gap-3 p-3 bg-(--inner-bg) border border-(--card-border) rounded-xl hover:border-(--accent) transition-colors group cursor-pointer"
                    >
                        <div
                            class="w-8 h-8 rounded-lg bg-(--inner-bg) group-hover:bg-(--accent)/10 flex items-center justify-center flex-shrink-0 transition-colors"
                        >
                            <Icon
                                name="mail"
                                size={14}
                                strokeWidth={2}
                                class="text-(--muted2) group-hover:text-(--accent) transition-colors"
                            />
                        </div>
                        <div class="text-left">
                            <p
                                class="text-[10px] text-(--muted2) uppercase tracking-wide"
                            >
                                Email
                            </p>
                            <p
                                class="text-sm text-(--muted) group-hover:text-white transition-colors"
                            >
                                {personal.email}
                            </p>
                        </div>
                    </button>
                    <button
                        @click.stop="navigator.clipboard.writeText(phone); showToast('Copied phone number to clipboard')"
                        class="w-full flex items-center gap-3 p-3 bg-(--inner-bg) border border-(--card-border) rounded-xl hover:border-(--accent) transition-colors group cursor-pointer"
                    >
                        <div
                            class="w-8 h-8 rounded-lg bg-(--inner-bg) group-hover:bg-(--accent)/10 flex items-center justify-center flex-shrink-0 transition-colors"
                        >
                            <Icon
                                name="phone"
                                size={14}
                                strokeWidth={2}
                                class="text-(--muted2) group-hover:text-(--accent) transition-colors"
                            />
                        </div>
                        <div class="text-left">
                            <p
                                class="text-[10px] text-(--muted2) uppercase tracking-wide"
                            >
                                Phone
                            </p>
                            <p
                                class="text-sm text-(--muted) group-hover:text-white transition-colors"
                            >
                                {personal.phone}
                            </p>
                        </div>
                    </button>
                </div>

                <p
                    class="text-[10px] text-(--muted2) uppercase tracking-wider mb-3"
                >
                    Profiles
                </p>
                <div class="grid grid-cols-2 gap-2">
                    {
                        social.map((s) => (
                            <a
                                href={s.url}
                                target="_blank"
                                rel="noopener"
                                class="flex items-center gap-2.5 p-3 bg-(--inner-bg) border border-(--card-border) rounded-xl hover:border-(--accent) hover:text-(--accent) text-(--muted) transition-colors"
                            >
                                <Icon name={s.icon} size={15} />
                                <span class="text-sm font-medium">
                                    {s.name}
                                </span>
                                <Icon
                                    name="arrow-up-right"
                                    size={9}
                                    strokeWidth={2.5}
                                    class="ml-auto opacity-40 flex-shrink-0"
                                />
                            </a>
                        ))
                    }
                </div>
            </Modal>

            <Modal
                name="projects"
                width="md:max-w-2xl lg:max-w-4xl"
                eyebrow="Projects"
                heading="Featured Projects"
            >
                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-[60vh] overflow-y-auto pr-1"
                >
                    {
                        sortedProjects.map((project) => (
                            <div class="bg-(--inner-bg) border border-(--card-border) rounded-xl overflow-hidden hover:border-(--dim-border) transition-colors">
                                <div class="relative" style="aspect-ratio: 16/7">
                                    <img
                                        src={project.data.image}
                                        alt={project.data.title}
                                        class="w-full h-full object-cover opacity-70"
                                    />
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
                                </div>
                                <div class="p-4">
                                    <div class="flex items-start justify-between gap-2 mb-2">
                                        <h3 class="text-white font-semibold text-sm">
                                            {project.data.title}
                                        </h3>
                                        {project.data.repo && (
                                            <a
                                                href={project.data.repo}
                                                target="_blank"
                                                rel="noopener"
                                                class="flex-shrink-0 text-(--muted2) hover:text-(--accent) transition-colors"
                                                title="View on GitHub"
                                            >
                                                <Icon name="github" size={14} />
                                            </a>
                                        )}
                                    </div>
                                    <p class="text-(--muted) text-xs leading-relaxed mb-3">
                                        {project.data.description}
                                    </p>
                                    <div class="flex flex-wrap gap-1">
                                        {project.data.tags.map((tag) => (
                                            <span class="tag">{tag}</span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </Modal>

            <div
                x-show="toast !== null"
                x-transition
                class="fixed bottom-6 left-1/2 transform -translate-x-1/2 bg-(--accent) text-black px-6 py-3 rounded-lg font-semibold text-sm shadow-lg"
            >
                <span x-text="toast"></span>
            </div>
        </div>
    </div>
</Base>
