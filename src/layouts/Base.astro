---
interface Props {
    title?: string;
}
const { title = "Aung Cho Oo — Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <link
            rel="icon"
            href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚙</text></svg>"
        />
        <style>
            @import url("https://fonts.googleapis.com/css2?family=Gelasio:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500;600&family=Birthstone&family=Tangerine:wght@700&display=swap");
        </style>
    </head>
    <body>
        <slot />

        <script>
            import Alpine from "alpinejs";
            (window as any).Alpine = Alpine;
            Alpine.start();
        </script>
    </body>
</html>

<style is:global>
    @import "../styles/global.css";
</style>
